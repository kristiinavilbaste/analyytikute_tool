# Server-side (set in Netlify dashboard for production — never expose to the browser)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Optional local Express server port
PORT=3001

# Frontend (Vite — only VITE_* vars are exposed to the client)
VITE_USE_MOCK_AI=false

# Production (Netlify):
VITE_API_BASE_URL=/.netlify/functions

# Local development (Express backend):
# VITE_API_BASE_URL=http://localhost:3001/api
